{
  "compilerOptions": {
    "target": "es5",
    "module": "commonjs",
    "types": ["node", "jasmine"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true
  }
}